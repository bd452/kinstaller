import { Theme } from "theme.slint";
import { AppState } from "state.slint";
import { InkButton, OutlineButton, ProgressBar } from "widgets.slint";

export component ConfirmScreen inherits VerticalLayout {
    padding: Theme.page-padding;
    spacing: Theme.gap;
    vertical-stretch: 1;

    Text {
        text: AppState.confirm-title;
        font-size: Theme.heading;
        font-weight: 700;
        color: Theme.ink;
        wrap: word-wrap;
    }

    Rectangle {
        background: Theme.grey-faint;
        border-width: 1px;
        border-color: Theme.grey-mid;
        border-radius: Theme.radius;
        VerticalLayout {
            padding: 12px;
            spacing: 4px;
            for line in AppState.confirm-lines: Text {
                text: "• " + line;
                font-size: Theme.body;
                color: Theme.ink;
                wrap: word-wrap;
            }
        }
    }

    Rectangle {}

    InkButton {
        text: "Confirm";
        enabled: !AppState.busy;
        clicked => { AppState.confirm-accepted(); }
    }

    OutlineButton {
        text: "Cancel";
        enabled: !AppState.busy;
        clicked => { AppState.confirm-cancelled(); }
    }
}

export component RunScreen inherits VerticalLayout {
    padding: Theme.page-padding;
    spacing: Theme.gap;
    vertical-stretch: 1;

    Text {
        text: AppState.run-title;
        font-size: Theme.heading;
        font-weight: 700;
        color: Theme.ink;
        wrap: word-wrap;
    }

    ProgressBar {
        percent: AppState.run-progress;
    }

    HorizontalLayout {
        Text {
            text: AppState.run-status;
            color: Theme.grey-text;
            font-size: Theme.caption;
            horizontal-stretch: 1;
        }
        Text {
            text: AppState.run-progress + "%";
            color: Theme.ink;
            font-size: Theme.body;
            font-weight: 700;
        }
    }

    Rectangle {
        min-height: 120px;
        background: Theme.grey-faint;
        border-width: 1px;
        border-color: Theme.grey-mid;
        border-radius: Theme.radius;
        vertical-stretch: 1;
        clip: true;
        VerticalLayout {
            padding: 8px;
            spacing: 2px;
            if AppState.run-log.length == 0 && !AppState.run-done: Text {
                text: "Waiting for output…";
                color: Theme.grey-text;
                font-size: Theme.caption;
                wrap: word-wrap;
            }
            Flickable {
                vertical-stretch: 1;
                log-layout := VerticalLayout {
                    padding: 0;
                    spacing: 2px;
                    for line in AppState.run-log: Text {
                        text: line.text;
                        color: line.is-error ? Theme.error : Theme.ink;
                        font-size: Theme.caption;
                        wrap: word-wrap;
                    }
                }
                viewport-height: log-layout.preferred-height;
                // Keep the most recent package-manager output visible as it arrives.
                viewport-y: min(0px, self.height - log-layout.preferred-height);
            }
        }
    }

    if !AppState.run-done: OutlineButton {
        text: "Working…";
        enabled: false;
        clicked => {}
    }

    if AppState.run-done: InkButton {
        text: AppState.run-failed ? "Back (failed)" : "Return to Kinstaller";
        clicked => { AppState.run-dismissed(); }
    }
}
